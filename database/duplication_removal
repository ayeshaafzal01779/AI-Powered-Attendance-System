SELECT '=== FINAL CHECK: Sessions per section (should be 30 past + 1 active) ===' AS verify_2;
SELECT
    c.course_code,
    d.dept_code,
    s.semester_number,
    COUNT(CASE WHEN sess.is_active = FALSE THEN 1 END) AS past_sessions,
