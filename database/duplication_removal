-- =========================================================
USE TriAttendanceDB;
SET SQL_SAFE_UPDATES = 0;
SET FOREIGN_KEY_CHECKS = 0;

-- =========================================================
-- DIAGNOSIS: Pehle check karo kya problem hai
-- =========================================================
SELECT '=== DIAGNOSIS: Teacher ke kitni sections hain ===' AS check_1;
SELECT
    t.employee_id,
    t.full_name,
    d.dept_code,
    COUNT(DISTINCT sec.section_id) AS total_sections,
    GROUP_CONCAT(c.course_code ORDER BY c.course_code) AS courses
FROM users t
JOIN departments d ON d.dept_id = t.dept_id
LEFT JOIN sections sec ON sec.teacher_id = t.user_id
LEFT JOIN course_semester cs ON cs.cs_id = sec.cs_id
LEFT JOIN courses c ON c.course_id = cs.course_id
WHERE t.role = 'Teacher'
GROUP BY t.user_id, t.employee_id, t.full_name, d.dept_code
HAVING COUNT(DISTINCT sec.section_id) > 1
ORDER BY d.dept_code, t.employee_id;

SELECT '=== DIAGNOSIS: Duplicate sessions per teacher per date ===' AS check_2;
SELECT
    t.full_name AS teacher_name,
    sess.session_date,
    COUNT(*) AS session_count,
    GROUP_CONCAT(DISTINCT c.course_code) AS courses
FROM attendance_sessions sess
JOIN users t ON t.user_id = sess.teacher_id
JOIN sections sec ON sec.section_id = sess.section_id
JOIN course_semester cs ON cs.cs_id = sec.cs_id
JOIN courses c ON c.course_id = cs.course_id
WHERE sess.session_date = CURDATE()
GROUP BY t.user_id, t.full_name, sess.session_date
HAVING COUNT(*) > 1
ORDER BY t.full_name
LIMIT 20;

-- =========================================================
-- FIX 1: REMOVE DUPLICATE SECTIONS
-- Agar kisi teacher ke paas ek hi course ke 2 sections hain
-- toh extra wala remove karo (sirf Section A rakhna hai)
-- =========================================================
SELECT '=== FIXING: Duplicate sections remove karna ===' AS fix_1;

-- Pehle duplicate enrollments hatao jo duplicate sections se aaye
DELETE se FROM student_enrollment se
WHERE se.section_id IN (
    SELECT section_id FROM (
        SELECT sec.section_id
        FROM sections sec
        JOIN course_semester cs ON cs.cs_id = sec.cs_id
        WHERE sec.section_id NOT IN (
            -- Keep only the FIRST (lowest) section_id per cs_id
            SELECT MIN(s2.section_id)
            FROM sections s2
            GROUP BY s2.cs_id
        )
    ) AS dup_sections
);

-- Duplicate attendance records bhi hatao
DELETE ar FROM attendance_records ar
WHERE ar.section_id IN (
    SELECT section_id FROM (
        SELECT sec.section_id
        FROM sections sec
        WHERE sec.section_id NOT IN (
            SELECT MIN(s2.section_id)
            FROM sections s2
            GROUP BY s2.cs_id
        )
    ) AS dup_sections
);

-- Duplicate sessions hatao
DELETE sess FROM attendance_sessions sess
WHERE sess.section_id IN (
    SELECT section_id FROM (
        SELECT sec.section_id
        FROM sections sec
        WHERE sec.section_id NOT IN (
            SELECT MIN(s2.section_id)
            FROM sections s2
            GROUP BY s2.cs_id
        )
    ) AS dup_sections
);

-- Ab duplicate sections khud hatao
DELETE FROM sections
WHERE section_id NOT IN (
    SELECT min_id FROM (
        SELECT MIN(section_id) AS min_id
        FROM sections
        GROUP BY cs_id
    ) AS keep_sections
);

-- =========================================================
-- FIX 2: DUPLICATE SESSIONS PER DAY PER SECTION
-- Ek section ka ek din mein sirf 1 session hona chahiye
-- =========================================================
SELECT '=== FIXING: Duplicate sessions per day per section ===' AS fix_2;

-- Duplicate attendance records from duplicate sessions
DELETE ar FROM attendance_records ar
WHERE ar.session_id IN (
    SELECT session_id FROM (
        SELECT sess.session_id
        FROM attendance_sessions sess
        WHERE sess.session_id NOT IN (
            SELECT MIN(s2.session_id)
            FROM attendance_sessions s2
            GROUP BY s2.section_id, s2.session_date, s2.is_active
        )
    ) AS dup_sess
);

-- Duplicate sessions hatao
DELETE FROM attendance_sessions
WHERE session_id NOT IN (
    SELECT min_sid FROM (
        SELECT MIN(session_id) AS min_sid
        FROM attendance_sessions
        GROUP BY section_id, session_date, is_active
    ) AS keep_sess
);

-- =========================================================
-- FIX 3: TEACHER DASHBOARD VIEW — Semester + Correct Sessions
-- Yeh view teacher ko sirf apna 1 course dikhata hai
-- with correct semester info
-- =========================================================
SELECT '=== CREATING: Teacher Dashboard View ===' AS fix_3;

CREATE OR REPLACE VIEW v_teacher_dashboard AS
SELECT
    t.user_id           AS teacher_id,
    t.full_name         AS teacher_name,
    t.email             AS teacher_email,
    t.employee_id,
    d.dept_code,
    d.dept_name,
    s.semester_number,
    s.semester_name,
    c.course_code,
    c.course_name,
    c.credit_hours,
    sec.section_id,
    sec.section_code,
    sec.room_no,
    sec.enrolled_count,
    -- Today's session status
    today_sess.session_id   AS today_session_id,
    today_sess.is_active    AS today_session_active,
    today_sess.start_time   AS today_start_time,
    -- Session counts
    COUNT(DISTINCT CASE WHEN past.is_active = FALSE
        THEN past.session_id END)  AS total_past_sessions,
    -- Today's attendance so far
    COALESCE(today_present.present_count, 0)  AS today_present,
    COALESCE(today_present.absent_count, 0)   AS today_absent,
    -- Overall class average
    ROUND(
        SUM(CASE WHEN ar.status = 'Present' THEN 1 ELSE 0 END) /
        NULLIF(COUNT(ar.record_id), 0) * 100, 2
    )                   AS overall_class_avg_pct
FROM users t
JOIN departments d      ON d.dept_id      = t.dept_id
JOIN sections sec       ON sec.teacher_id = t.user_id
JOIN course_semester cs ON cs.cs_id       = sec.cs_id
JOIN courses c          ON c.course_id    = cs.course_id
JOIN semesters s        ON s.sem_id       = cs.sem_id
-- Today's active session
LEFT JOIN attendance_sessions today_sess
    ON today_sess.section_id  = sec.section_id
    AND today_sess.session_date = CURDATE()
    AND today_sess.is_active  = TRUE
-- All past sessions
LEFT JOIN attendance_sessions past
    ON past.section_id = sec.section_id
    AND past.is_active = FALSE
-- All past attendance records
LEFT JOIN attendance_records ar
    ON ar.section_id = sec.section_id
    AND ar.session_id = past.session_id
-- Today's attendance count
LEFT JOIN (
    SELECT
        sess2.section_id,
        SUM(CASE WHEN ar2.status='Present' THEN 1 ELSE 0 END) AS present_count,
        SUM(CASE WHEN ar2.status='Absent'  THEN 1 ELSE 0 END) AS absent_count
    FROM attendance_sessions sess2
    JOIN attendance_records ar2 ON ar2.session_id = sess2.session_id
    WHERE sess2.session_date = CURDATE()
    GROUP BY sess2.section_id
) today_present ON today_present.section_id = sec.section_id
WHERE t.role = 'Teacher'
GROUP BY
    t.user_id, t.full_name, t.email, t.employee_id,
    d.dept_code, d.dept_name,
    s.semester_number, s.semester_name,
    c.course_code, c.course_name, c.credit_hours,
    sec.section_id, sec.section_code, sec.room_no, sec.enrolled_count,
    today_sess.session_id, today_sess.is_active, today_sess.start_time,
    today_present.present_count, today_present.absent_count
ORDER BY d.dept_code, s.semester_number, t.full_name;

-- =========================================================
-- FIX 4: TEACHER SESSION LIST VIEW
-- Teacher apne course ke sirf apne sessions dekhe
-- Last 30 days + today — with semester
-- =========================================================
CREATE OR REPLACE VIEW v_teacher_sessions_list AS
SELECT
    t.user_id           AS teacher_id,
    t.full_name         AS teacher_name,
    t.employee_id,
    d.dept_code,
    s.semester_number,
    s.semester_name,
    c.course_code,
    c.course_name,
    sec.section_code,
    sec.section_id,
    sess.session_id,
    sess.session_date,
    DAYNAME(sess.session_date)  AS day_name,
    TIME(sess.start_time)       AS start_time,
    TIME(sess.end_time)         AS end_time,
    sess.mode                   AS session_mode,
    sess.is_active,
    -- Attendance counts for this session
    COUNT(DISTINCT se.student_id)                               AS enrolled,
    SUM(CASE WHEN ar.status = 'Present' THEN 1 ELSE 0 END)     AS present_count,
    SUM(CASE WHEN ar.status = 'Absent'  THEN 1 ELSE 0 END)     AS absent_count,
    COUNT(ar.record_id)                                         AS marked_count,
    ROUND(
        SUM(CASE WHEN ar.status='Present' THEN 1 ELSE 0 END) /
        NULLIF(COUNT(DISTINCT se.student_id), 0) * 100, 2
    )                           AS session_pct
FROM users t
JOIN departments d          ON d.dept_id      = t.dept_id
JOIN sections sec           ON sec.teacher_id = t.user_id
JOIN course_semester cs     ON cs.cs_id       = sec.cs_id
JOIN courses c              ON c.course_id    = cs.course_id
JOIN semesters s            ON s.sem_id       = cs.sem_id
JOIN attendance_sessions sess
    ON sess.section_id  = sec.section_id
    AND sess.teacher_id = t.user_id
    AND (
        sess.session_date >= DATE_SUB(CURDATE(), INTERVAL 30 DAY)
        OR sess.session_date = CURDATE()
    )
JOIN student_enrollment se  ON se.section_id = sec.section_id
LEFT JOIN attendance_records ar
    ON ar.session_id  = sess.session_id
    AND ar.student_id = se.student_id
WHERE t.role = 'Teacher'
GROUP BY
    t.user_id, t.full_name, t.employee_id,
    d.dept_code, s.semester_number, s.semester_name,
    c.course_code, c.course_name,
    sec.section_code, sec.section_id,
    sess.session_id, sess.session_date, sess.start_time,
    sess.end_time, sess.mode, sess.is_active
ORDER BY sess.session_date DESC, t.full_name;

-- =========================================================
-- FIX 5: UPDATE v_report_student_attendance — Add semester clearly
-- =========================================================
CREATE OR REPLACE VIEW v_report_student_attendance AS
SELECT
    u.user_id                                               AS student_id,
    u.registration_no,
    u.full_name                                             AS student_name,
    u.email                                                 AS student_email,
    u.phone                                                 AS student_phone,
    d.dept_code,
    d.dept_name,
    p.program_name,
    p.program_code,
    s.semester_number                                       AS current_semester,
    s.semester_name,
    s.start_date                                            AS semester_start,
    s.end_date                                              AS semester_end,
    c.course_code,
    c.course_name,
    c.credit_hours,
    c.course_type,
    t.full_name                                             AS teacher_name,
    t.email                                                 AS teacher_email,
    t.qualification                                         AS teacher_qualification,
    sec.section_code,
    sec.room_no,
    COUNT(ar.record_id)                                     AS total_sessions,
    SUM(CASE WHEN ar.status = 'Present' THEN 1 ELSE 0 END) AS present_count,
    SUM(CASE WHEN ar.status = 'Absent'  THEN 1 ELSE 0 END) AS absent_count,
    ROUND(
        SUM(CASE WHEN ar.status = 'Present' THEN 1 ELSE 0 END) /
        NULLIF(COUNT(ar.record_id), 0) * 100, 2
    )                                                       AS attendance_pct,
    CASE
        WHEN ROUND(
            SUM(CASE WHEN ar.status='Present' THEN 1 ELSE 0 END) /
            NULLIF(COUNT(ar.record_id),0) * 100, 2
        ) = 100 THEN 'Perfect'
        WHEN ROUND(
            SUM(CASE WHEN ar.status='Present' THEN 1 ELSE 0 END) /
            NULLIF(COUNT(ar.record_id),0) * 100, 2
        ) >= 90  THEN 'Excellent'
        WHEN ROUND(
            SUM(CASE WHEN ar.status='Present' THEN 1 ELSE 0 END) /
            NULLIF(COUNT(ar.record_id),0) * 100, 2
        ) >= 80  THEN 'Good'
        WHEN ROUND(
            SUM(CASE WHEN ar.status='Present' THEN 1 ELSE 0 END) /
            NULLIF(COUNT(ar.record_id),0) * 100, 2
        ) >= 75  THEN 'Satisfactory'
        ELSE 'At Risk'
    END                                                     AS attendance_status,
    MIN(ar.attendance_date)                                 AS first_session_date,
    MAX(ar.attendance_date)                                 AS last_session_date
FROM users u
JOIN departments d          ON d.dept_id      = u.dept_id
JOIN programs p             ON p.program_id   = u.program_id
JOIN semesters s            ON s.sem_id       = u.current_sem_id
JOIN student_enrollment se  ON se.student_id  = u.user_id
JOIN sections sec           ON sec.section_id = se.section_id
JOIN course_semester cs     ON cs.cs_id       = sec.cs_id
JOIN courses c              ON c.course_id    = cs.course_id
JOIN semesters s2           ON s2.sem_id      = cs.sem_id
JOIN users t                ON t.user_id      = sec.teacher_id
LEFT JOIN attendance_records ar
    ON ar.student_id = u.user_id AND ar.section_id = sec.section_id
WHERE u.role = 'Student'
  AND s2.sem_id = s.sem_id   -- Only current semester courses
GROUP BY
    u.user_id, u.registration_no, u.full_name, u.email, u.phone,
    d.dept_code, d.dept_name, p.program_name, p.program_code,
    s.semester_number, s.semester_name, s.start_date, s.end_date,
    c.course_code, c.course_name, c.credit_hours, c.course_type,
    t.full_name, t.email, t.qualification, sec.section_code, sec.room_no
ORDER BY d.dept_code, s.semester_number, u.registration_no, c.course_code;

-- =========================================================
-- FIX 6: UPDATE v_report_low_attendance — Add semester
-- =========================================================
CREATE OR REPLACE VIEW v_report_low_attendance AS
SELECT
    u.user_id,
    u.registration_no,
    u.full_name             AS student_name,
    u.email,
    u.phone,
    d.dept_code,
    d.dept_name,
    s.semester_number,
    s.semester_name,
    c.course_code,
    c.course_name,
    t.full_name             AS teacher_name,
    t.email                 AS teacher_email,
    sec.section_code,
    COUNT(ar.record_id)                                     AS total_sessions,
    SUM(CASE WHEN ar.status='Present' THEN 1 ELSE 0 END)   AS present_count,
    SUM(CASE WHEN ar.status='Absent'  THEN 1 ELSE 0 END)   AS absent_count,
    ROUND(
        SUM(CASE WHEN ar.status='Present' THEN 1 ELSE 0 END) /
        NULLIF(COUNT(ar.record_id), 0) * 100, 2
    )                       AS attendance_pct,
    COALESCE(f.fine_amount, 0)              AS fine_amount,
    COALESCE(f.status, 'No Fine Issued')    AS fine_status,
    f.issued_date           AS fine_issued_date,
    f.paid_date             AS fine_paid_date
FROM users u
JOIN departments d          ON d.dept_id      = u.dept_id
JOIN programs p             ON p.program_id   = u.program_id
JOIN semesters s            ON s.sem_id       = u.current_sem_id
JOIN student_enrollment se  ON se.student_id  = u.user_id
JOIN sections sec           ON sec.section_id = se.section_id
JOIN course_semester cs     ON cs.cs_id       = sec.cs_id
JOIN courses c              ON c.course_id    = cs.course_id
JOIN semesters s2           ON s2.sem_id      = cs.sem_id AND s2.sem_id = s.sem_id
JOIN users t                ON t.user_id      = sec.teacher_id
LEFT JOIN attendance_records ar
    ON ar.student_id  = u.user_id
    AND ar.section_id = sec.section_id
LEFT JOIN fines f
    ON f.student_id   = u.user_id
    AND f.course_code = c.course_code
WHERE u.role = 'Student'
GROUP BY
    u.user_id, u.registration_no, u.full_name, u.email, u.phone,
    d.dept_code, d.dept_name, s.semester_number, s.semester_name,
    c.course_code, c.course_name, t.full_name, t.email,
    sec.section_code, f.fine_amount, f.status, f.issued_date, f.paid_date
HAVING attendance_pct < 75
ORDER BY attendance_pct ASC, d.dept_code, s.semester_number, c.course_code;

-- =========================================================
-- FIX 7: STORED PROCEDURE — Teacher ke liye apna dashboard data
-- Backend yeh call kare: CALL sp_teacher_dashboard(teacher_user_id);
-- =========================================================
DROP PROCEDURE IF EXISTS sp_teacher_dashboard;
DELIMITER $$
CREATE PROCEDURE sp_teacher_dashboard(IN p_teacher_id INT)
BEGIN
    -- Teacher info + course + semester
    SELECT
        teacher_name, teacher_email, employee_id,
        dept_code, dept_name,
        semester_number, semester_name,
        course_code, course_name,
        section_code, room_no, enrolled_count,
        today_session_id, today_session_active,
        total_past_sessions,
        today_present, today_absent,
        overall_class_avg_pct
    FROM v_teacher_dashboard
    WHERE teacher_id = p_teacher_id;

    -- Last 30 days session list (only this teacher's course)
    SELECT
        session_date, day_name, start_time, end_time,
        semester_number, semester_name,
        course_code, section_code,
        enrolled, present_count, absent_count, session_pct, is_active
    FROM v_teacher_sessions_list
    WHERE teacher_id = p_teacher_id
    ORDER BY session_date DESC
    LIMIT 30;
END$$
DELIMITER ;

