-- STEP 5: SECTIONS + ENROLLMENT
-- Each course gets ONE section (all 20 students in it)
-- Teacher assignment: each teacher owns 1 course in their semester
-- Teacher → Course mapping by employee_id suffix
-- =========================================================
USE TriAttendanceDB;

-- =========================================================
-- CREATE SECTIONS
-- One section per course_semester record
-- Teacher matched by their employee_id which aligns with course code
-- =========================================================

-- CS SECTIONS
INSERT INTO sections (cs_id, section_code, teacher_id, room_no, capacity, enrolled_count, is_active)
SELECT
    cs.cs_id,
    'A',
    CASE c.course_code
        WHEN 'CS201' THEN (SELECT user_id FROM users WHERE employee_id='TCH-CS-201' LIMIT 1)
        WHEN 'CS202' THEN (SELECT user_id FROM users WHERE employee_id='TCH-CS-202' LIMIT 1)
