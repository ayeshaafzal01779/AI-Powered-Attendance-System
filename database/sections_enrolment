-- VERIFY
-- =========================================================
SELECT 'STEP 5 COMPLETE' AS status;
SELECT COUNT(*) AS total_sections FROM sections;
SELECT COUNT(*) AS total_enrollments FROM student_enrollment;

SELECT d.dept_code, s.semester_number, c.course_code, sec.enrolled_count
FROM sections sec
JOIN course_semester cs ON cs.cs_id = sec.cs_id
JOIN courses c ON c.course_id = cs.course_id
JOIN departments d ON d.dept_id = c.dept_id
JOIN semesters s ON s.sem_id = cs.sem_id
ORDER BY d.dept_code, s.semester_number, c.course_code
LIMIT 40;