-- =========================================================
-- ENROLL STUDENTS INTO SECTIONS
-- Each student enrolled in all 5 courses of their semester
-- Match: student's current_sem_id → section's semester via cs_id
-- =========================================================
INSERT INTO student_enrollment (student_id, section_id)
SELECT DISTINCT u.user_id, sec.section_id
FROM users u
JOIN sections sec ON sec.cs_id IN (
    SELECT cs.cs_id
    FROM course_semester cs
    JOIN semesters s ON s.sem_id = cs.sem_id
    WHERE s.sem_id = u.current_sem_id
)
JOIN course_semester cs2 ON cs2.cs_id = sec.cs_id
JOIN courses c ON c.course_id = cs2.course_id
WHERE u.role = 'Student'
  AND c.dept_id = u.dept_id
  AND NOT EXISTS (
      SELECT 1 FROM student_enrollment se2
      WHERE se2.student_id = u.user_id AND se2.section_id = sec.section_id
  );

-- =========================================================
-- UPDATE enrolled_count
-- =========================================================
SET SQL_SAFE_UPDATES = 0;
UPDATE sections sec
SET enrolled_count = (
    SELECT COUNT(*) FROM student_enrollment se WHERE se.section_id = sec.section_id
);
SET SQL_SAFE_UPDATES = 1;

