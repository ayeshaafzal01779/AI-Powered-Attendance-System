FLASK_SECRET_KEY=replace_with_a_long_random_secret
FLASK_DEBUG=false
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=TriAttendanceDB

GMAIL_USER=your_email@gmail.com
GMAIL_PASSWORD=your_gmail_app_password

# Comma-separated list, used for CORS
# Add your laptop LAN IP origin for mobile testing, e.g. http://192.168.1.100:5000
CORS_ORIGINS=http://127.0.0.1:5000,http://localhost:5000,http://192.168.1.100:5000
